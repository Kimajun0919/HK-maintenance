# Hugging Face access token.
# Required only when HF_DEPLOY=1.
HF_TOKEN=hf_your_token_here

# Space repo id. Format: username/space-name
HF_SPACE_ID=your-username/hk-maintenance-rag

# Set to 1 to upload after preparing hf_space_bundle.
HF_DEPLOY=0

# Optional runtime settings.
# Use USE_LLM=0 for fast source-based answers and Render free-tier deployments.
# Set USE_LLM=1 only for local testing on a machine with enough memory for the model.
USE_LLM=0
LOCAL_LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
MAX_NEW_TOKENS=512

# Keep deployment small. Set to 1 only if image browsing inside Space is required.
HF_INCLUDE_IMAGES=0

# Optional: Supabase/Postgres-backed document CRUD.
# If SUPABASE_DB_URL is set, the app stores md documents in Supabase instead of runtime files.
# DOC_STORAGE=supabase
# SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require
# SUPABASE_DOCS_TABLE=maintenance_docs
# SUPABASE_ASSETS_TABLE=maintenance_docs_assets
# SUPABASE_FOLDERS_TABLE=maintenance_docs_folders
# SUPABASE_CHUNKS_TABLE=maintenance_docs_chunks
# SUPABASE_AUTO_MIGRATE=1
# SUPABASE_SEED_FROM_FILES=1

# Multiple Supabase profiles.
# Set SUPABASE_PROFILE to choose a suffix. For SUPABASE_PROFILE=fresh, the app
# reads SUPABASE_DB_URL_FRESH. Profile mode is strict by default, so a missing
# profile URL will not fall back to the old SUPABASE_DB_URL.
# SUPABASE_PROFILE=fresh
# SUPABASE_PROFILE_STRICT=1
# SUPABASE_DB_URL_MAIN=postgresql://postgres.main-project-ref:password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require
# SUPABASE_DB_URL_FRESH=postgresql://postgres.fresh-project-ref:password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require
# SUPABASE_SEED_FROM_FILES_FRESH=0
# SUPABASE_DOCS_TABLE_FRESH=maintenance_docs
# SUPABASE_REQUESTS_TABLE_FRESH=maintenance_requests

# Optional structured CSV import tables for `유지보수 접수내역.csv`.
# SUPABASE_REQUESTS_TABLE=maintenance_requests
# SUPABASE_REQUEST_IMPORTS_TABLE=maintenance_requests_imports

# Fresh DB bootstrap target. Keep this separate from SUPABASE_DB_URL so scripts
# cannot accidentally initialize the currently connected DB.
# NEW_SUPABASE_DB_URL=postgresql://postgres.your-new-project-ref:your-db-password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require

# Search embeddings. Use EMBEDDING_BACKEND=none on Render free tier to avoid loading
# the local Hugging Face sentence-transformers model during web requests.
# sentence-transformers is optional and not installed by the production Docker image.
# For local vector rebuilds: pip install -r backend/requirements-embeddings.txt
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# EMBEDDING_DIM=384
# EMBEDDING_BACKEND=none
# EMBEDDING_BACKEND=sentence-transformers

# Render free tier memory saver. BM25 search remains enabled; these disable
# extra in-memory n-gram and legacy cosine indexes.
# RAG_ENABLE_NGRAM_INDEX=0
# RAG_ENABLE_LEGACY_INDEX=0
